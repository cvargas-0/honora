{
  "database": { "driver": "sqlite", "url": "./data.db" },
  "middleware": ["cors", "logger"],
  "openapi": true,
  "collections": [
    {
      "name": "users",
      "methos": ["get", "getById", "post", "put", "patch", "delete", "options"],
      "fields": {
        "name": { "type": "text", "required": true },
        "email": { "type": "text", "required": true, "unique": true },
        "age": { "type": "integer" }
      }
    },
    {
      "name": "posts",
      "methods": ["get", "getById", "post", "put", "delete"],
      "fields": {
        "title": { "type": "text", "required": true },
        "body": { "type": "text" },
        "author": {
          "type": "relation",
          "collection": "users",
          "required": true
        }
      }
    }
  ]
}
