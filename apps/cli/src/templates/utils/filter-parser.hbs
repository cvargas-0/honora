import { eq, ne, gt, gte, lt, lte, like, and } from "drizzle-orm";
{{#if (eq lang "ts")}}
import type { Column, SQL } from "drizzle-orm";

type OpFn = (col: Column, val: unknown) => SQL;
{{/if}}

// Reserved query params that are not filter fields
const RESERVED = new Set(["page", "perPage", "sort"]);

{{#if (eq lang "ts")}}
const OPS: Record<string, OpFn> = {
  eq:   (col, val) => eq(col, val as any),
  ne:   (col, val) => ne(col, val as any),
  gt:   (col, val) => gt(col, val as any),
  gte:  (col, val) => gte(col, val as any),
  lt:   (col, val) => lt(col, val as any),
  lte:  (col, val) => lte(col, val as any),
  like: (col, val) => like(col, `%${val}%` as any),
};
{{else}}
const OPS = {
  eq:   (col, val) => eq(col, val),
  ne:   (col, val) => ne(col, val),
  gt:   (col, val) => gt(col, val),
  gte:  (col, val) => gte(col, val),
  lt:   (col, val) => lt(col, val),
  lte:  (col, val) => lte(col, val),
  like: (col, val) => like(col, `%${val}%`),
};
{{/if}}

function parseValue(raw{{#if (eq lang "ts")}}: string{{/if}}){{#if (eq lang "ts")}}: unknown{{/if}} {
  if (raw === "true") return true;
  if (raw === "false") return false;
  if (raw === "null") return null;
  const num = Number(raw);
  if (!isNaN(num) && raw !== "") return num;
  return raw;
}

/**
 * Builds a Drizzle WHERE clause from URL query params.
 *
 * Supported syntaxes:
 *   Equality:   ?color=blue           → WHERE color = 'blue'
 *   Operators:  ?price[gte]=100       → WHERE price >= 100
 *               ?name[like]=ferrari   → WHERE name LIKE '%ferrari%'
 *
 * Supported operators: eq, ne, gt, gte, lt, lte, like
 * Multiple params are combined with AND.
 */
export function buildWhere(
  columns{{#if (eq lang "ts")}}: Record<string, Column>{{/if}},
  validFields{{#if (eq lang "ts")}}: Set<string>{{/if}},
  queryParams{{#if (eq lang "ts")}}: Record<string, string>{{/if}}
){{#if (eq lang "ts")}}: SQL | undefined{{/if}} {
  const conditions{{#if (eq lang "ts")}}: SQL[]{{/if}} = [];

  for (const [key, rawValue] of Object.entries(queryParams)) {
    if (RESERVED.has(key)) continue;

    // Parse "field[op]" or plain "field" (defaults to eq)
    const bracketMatch = key.match(/^(\w+)\[(\w+)\]$/);
    const field = bracketMatch ? bracketMatch[1] : key;
    const opName = bracketMatch ? bracketMatch[2] : "eq";

    if (!validFields.has(field)) continue;
    const col = columns[field{{#if (eq lang "ts")}} as keyof typeof columns{{/if}}];
    if (!col) continue;

    const fn = OPS[opName{{#if (eq lang "ts")}} as keyof typeof OPS{{/if}}];
    if (!fn) continue;

    conditions.push(fn(col, parseValue(rawValue)));
  }

  if (conditions.length === 0) return undefined;
  return conditions.length === 1 ? conditions[0] : and(...conditions);
}
