{
  "name": "create-honora",
  "version": "0.4.3",
  "description": "Generate a REST API project from a JSON schema.",
  "license": "MIT",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "create-honora": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "api",
    "rest",
    "crud",
    "cli",
    "schema",
    "scaffold",
    "codegen"
  ],
  "author": {
    "name": "Camilo Vargas",
    "url": "https://cvargas.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cvargas-0/honora.git",
    "directory": "apps/cli"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@honora/generator": "workspace:*",
    "@honora/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
