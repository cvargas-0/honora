import { Hono } from "hono";
{{#each collections}}
{{#if (eq ../lang "js")}}
import {{name}} from "./{{name}}.js";
{{else}}
import {{name}} from "./{{name}}";
{{/if}}
{{/each}}

const app = new Hono();

{{#each collections}}
app.route("/api/{{name}}", {{name}});
{{/each}}

app.get("/api/_health", (c) => c.json({ status: "ok" }));

const schemaConfig = {{{schemaJson}}};

app.get("/api/_schema", (c) => c.json(schemaConfig));

export default app;
