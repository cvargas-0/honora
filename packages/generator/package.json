{
  "name": "@honora/generator",
  "version": "0.1.0",
  "description": "Project generator for Honora CLI",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@honora/types": "workspace:*",
    "handlebars": "^4.7.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/handlebars": "*",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
