{{#if (eq lang "ts")}}
type PrismaWhere = Record<string, unknown>;

{{/if}}
// Reserved query params that are not filter fields
const RESERVED = new Set(["page", "perPage", "sort"]);

const OPS{{#if (eq lang "ts")}}: Record<string, string>{{/if}} = {
  eq:   "equals",
  ne:   "not",
  gt:   "gt",
  gte:  "gte",
  lt:   "lt",
  lte:  "lte",
  like: "contains",
};

function parseValue(raw{{#if (eq lang "ts")}}: string{{/if}}){{#if (eq lang "ts")}}: unknown{{/if}} {
  const trimmed = raw.trim();
  if (trimmed === "true") return true;
  if (trimmed === "false") return false;
  if (trimmed === "null") return null;
  const num = Number(trimmed);
  if (!isNaN(num) && trimmed !== "") return num;
  return trimmed.replace(/^["']|["']$/g, "");
}

/**
 * Builds a Prisma WHERE clause from URL query params.
 *
 * Supported syntaxes:
 *   Equality:   ?color=blue           → WHERE color = 'blue'
 *   Operators:  ?price[gte]=100       → WHERE price >= 100
 *               ?name[like]=ferrari   → WHERE name CONTAINS 'ferrari'
 *
 * Supported operators: eq, ne, gt, gte, lt, lte, like
 * Multiple params are combined with AND.
 */
export function buildWhere(validFields{{#if (eq lang "ts")}}: Set<string>{{/if}}, queryParams{{#if (eq lang "ts")}}: Record<string, string>{{/if}}){{#if (eq lang "ts")}}: PrismaWhere | undefined{{/if}} {
  const conditions{{#if (eq lang "ts")}}: PrismaWhere[]{{/if}} = [];

  for (const [key, rawValue] of Object.entries(queryParams)) {
    if (RESERVED.has(key)) continue;

    // Parse "field[op]" or plain "field" (defaults to eq)
    const bracketMatch = key.match(/^(\w+)\[(\w+)\]$/);
    const field = bracketMatch ? bracketMatch[1] : key;
    const opName = bracketMatch ? bracketMatch[2] : "eq";

    if (!validFields.has(field)) continue;

    const prismaOp = OPS[opName{{#if (eq lang "ts")}} as keyof typeof OPS{{/if}}];
    if (!prismaOp) continue;

    const value = parseValue(rawValue);
    if (prismaOp === "equals") {
      conditions.push({ [field]: value });
    } else {
      conditions.push({ [field]: { [prismaOp]: value } });
    }
  }

  if (conditions.length === 0) return undefined;
  if (conditions.length === 1) return conditions[0];
  return { AND: conditions };
}
