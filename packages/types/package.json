{
  "name": "@honora/types",
  "version": "0.5.0",
  "description": "TypeScript types and schemas for Honora — the REST API code generator",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "honora",
    "types",
    "schema",
    "rest",
    "api",
    "codegen",
    "hono"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cvargas-0/honora.git",
    "directory": "packages/types"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "default": "./dist/schemas.js"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "default": "./dist/adapters.js"
    }
  },
  "author": {
    "name": "Camilo Vargas",
    "url": "https://cvargas.dev"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
