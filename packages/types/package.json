{
  "name": "@honora/types",
  "version": "1.0.0",
  "description": "TypeScript types for Honora CLI",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "default": "./dist/schemas.js"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "default": "./dist/adapters.js"
    }
  },
  "author": {
    "name": "Camilo Vargas",
    "url": "https://cvargas.dev"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}